# Server environment variables
# Copy this to .env and fill in your values
# For Amplify/Render: Set these as environment variables in the dashboard

# ============================================
# AI PROVIDERS (configure at least ONE)
# ============================================
# The system races all configured providers and uses the fastest response.
# OpenAI is recommended for highest quality.

# RECOMMENDED: OpenAI (GPT-4o)
# Get a key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your-openai-api-key-here

# OPTION 2: Together.ai (Llama 3.1 70B — Free Tier)
# Get a FREE key at: https://api.together.xyz
TOGETHER_API_KEY=your-together-api-key-here
VITE_TOGETHER_API_KEY=your-together-api-key-here
TOGETHER_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo
VITE_TOGETHER_MODEL=meta-llama/Llama-3.1-70B-Instruct-Turbo

# OPTION 3: Groq (Ultra-Fast LPU — Free Tier)
# Free key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
VITE_GROQ_API_KEY=your-groq-api-key-here

# ============================================
# Server Configuration
# ============================================
PORT=3004
NODE_ENV=development

# Frontend URL (for CORS) - Update for production
FRONTEND_URL=http://localhost:5173

# ============================================
# Feature Flags (Vite-compatible VITE_* prefix)
# ============================================
VITE_USE_REAL_AI=true
VITE_USE_REAL_DATA=true
VITE_USE_REAL_BACKEND=true
VITE_SHOW_DEMO_INDICATORS=false
VITE_ENABLE_SELF_LEARNING=true

# Enable external data sources (World Bank, Numbeo, OpenCorporates)
VITE_ENABLE_EXTERNAL_DATA=true
# NUMBEO_API_KEY or VITE_NUMBEO_API_KEY for frontend
# VITE_NUMBEO_API_KEY=your-numbeo-key
# OPEN_CORPORATES_API_KEY=your-opencorporates-key
# VITE_GEMINI_API_KEY=your-gemini-key
VITE_DEBUG_RESEARCH=true

# ============================================
# Autonomous Mode
# ============================================
AUTONOMOUS_MODE_DEFAULT=true
AUTO_ACT_ENABLED=true

# ============================================
# Optional: Additional Services
# ============================================
# ANTHROPIC_API_KEY=your-anthropic-key-here
# SERPER_API_KEY=your-serper-key-here

# ============================================
# Entity Intelligence Pipeline (Tier 1+2)
# ============================================
# Tavily — AI-optimized search (free tier: 1000 searches/mo)
# Get a key at: https://tavily.com
# VITE_TAVILY_API_KEY=your-tavily-api-key-here

# Brave Search — Independent non-Google web index (free tier: 2000 queries/mo)
# Get a key at: https://brave.com/search/api/
# VITE_BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# GLEIF — Legal Entity Identifiers (FREE, no key required)
# OpenSanctions — Sanctions/PEP screening (FREE, no key required for basic)
# V-Dem — Academic governance data (embedded, no key required)
